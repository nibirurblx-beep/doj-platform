# ============================================================================
# DOJ Platform environment variables
# Copy to .env.local for local development. NEVER commit real values.
# Variables without NEXT_PUBLIC_ are server-only and must never reach the
# client bundle.
# ============================================================================

# --- Supabase (Phase 1B onwards) --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key: server-only. Used exclusively inside server actions and
# route handlers for privileged operations. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Discord OAuth (Phase 1I) ------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Google Drive service account (Phase 1H) ---------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# JSON key, base64-encoded to survive env var storage. Server-only.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# --- Transactional email via Resend (Phase 1B) -----
# Sign up at resend.com (free tier available)
RESEND_API_KEY=re_...

# Platform owner: the only account that can grant/revoke global roles
# (Platform Administrator). Also protected from suspension/deletion.
OWNER_EMAIL=

# Sender for platform emails; must be at a domain verified in Resend
EMAIL_FROM="DOJ Roleplay <no-reply@doj-osfusa.online>"
